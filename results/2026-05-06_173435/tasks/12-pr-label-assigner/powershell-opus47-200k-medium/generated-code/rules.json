{
  "rules": [
    { "pattern": "docs/**",     "labels": ["documentation"], "priority": 10 },
    { "pattern": "src/api/**",  "labels": ["api", "backend"], "priority": 5 },
    { "pattern": "src/web/**",  "labels": ["frontend"],      "priority": 5 },
    { "pattern": "**/*.test.*", "labels": ["tests"],         "priority": 1 },
    { "pattern": "*.md",        "labels": ["documentation"], "priority": 10 }
  ]
}
