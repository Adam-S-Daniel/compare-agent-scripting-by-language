{
  "version": "1.0",
  "description": "Label assignment rules for PR changes",
  "rules": [
    {
      "pattern": "docs/**",
      "labels": ["documentation"],
      "priority": 10
    },
    {
      "pattern": "src/api/**",
      "labels": ["api"],
      "priority": 20
    },
    {
      "pattern": "src/**",
      "labels": ["code"],
      "priority": 5
    },
    {
      "pattern": "*.test.ps1",
      "labels": ["tests"],
      "priority": 15
    },
    {
      "pattern": "*.md",
      "labels": ["documentation"],
      "priority": 10
    },
    {
      "pattern": ".github/workflows/**",
      "labels": ["ci/cd"],
      "priority": 8
    }
  ]
}
