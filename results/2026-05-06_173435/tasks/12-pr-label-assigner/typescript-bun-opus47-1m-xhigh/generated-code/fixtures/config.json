{
  "rules": [
    { "label": "documentation", "patterns": ["docs/**", "*.md"], "priority": 5 },
    { "label": "api", "patterns": ["src/api/**"], "priority": 20 },
    { "label": "tests", "patterns": ["**/*.test.*", "tests/**"], "priority": 10 },
    { "label": "ci", "patterns": [".github/workflows/**", "Dockerfile", "**/*.yml"], "priority": 15 },
    { "label": "size/small", "patterns": ["small/**"], "priority": 1 },
    { "label": "size/large", "patterns": ["large/**"], "priority": 30 }
  ],
  "exclusiveGroups": [
    { "labels": ["size/small", "size/large"] }
  ]
}
