[
  { "label": "documentation", "patterns": ["docs/**", "**/*.md"], "priority": 1 },
  { "label": "api", "patterns": ["src/api/**"], "priority": 2 },
  { "label": "tests", "patterns": ["**/*.test.ts", "**/*.spec.ts", "tests/**"], "priority": 3 },
  { "label": "ci", "patterns": [".github/**"], "priority": 4 },
  { "label": "config", "patterns": ["*.json", "*.toml", "*.yaml", "*.yml"], "exclude": [".github/**"], "priority": 5 }
]
