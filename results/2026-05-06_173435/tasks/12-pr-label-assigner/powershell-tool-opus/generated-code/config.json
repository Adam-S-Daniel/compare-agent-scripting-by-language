{
  "rules": [
    {
      "pattern": "docs/**",
      "label": "documentation",
      "priority": 1
    },
    {
      "pattern": "*.md",
      "label": "documentation",
      "priority": 5
    },
    {
      "pattern": "src/api/**",
      "label": "api",
      "priority": 2
    },
    {
      "pattern": "src/**",
      "label": "backend",
      "priority": 10
