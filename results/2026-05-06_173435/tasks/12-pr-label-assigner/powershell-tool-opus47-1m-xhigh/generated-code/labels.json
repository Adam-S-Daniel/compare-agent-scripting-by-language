{
  "rules": [
    { "pattern": "docs/**",                "labels": ["documentation"],            "priority": 10 },
    { "pattern": "**/README*",             "labels": ["documentation"],            "priority": 10 },
    { "pattern": "src/api/**",             "labels": ["api", "backend"],           "priority": 50 },
    { "pattern": "src/web/**",             "labels": ["frontend"],                 "priority": 40 },
    { "pattern": "**/*.test.*",            "labels": ["tests"],                    "priority": 30 },
    { "pattern": "tests/**",               "labels": ["tests"],                    "priority": 30 },
    { "pattern": "**/*.cs",                "labels": ["csharp"],                   "priority": 20 },
    { "pattern": "**/*.ps1",               "labels": ["powershell"],               "priority": 20 },
    { "pattern": "**/*.psm1",              "labels": ["powershell"],               "priority": 20 },
    { "pattern": ".github/workflows/**",   "labels": ["ci"],                       "priority": 60 }
  ]
}
