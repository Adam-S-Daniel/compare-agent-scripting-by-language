{
  "rules": [
    { "pattern": "src/api/**",   "labels": ["api"],                       "priority": 100 },
    { "pattern": "src/web/**",   "labels": ["frontend"],                  "priority": 90  },
    { "pattern": ".github/**",   "labels": ["ci", "infrastructure"],      "priority": 75  },
    { "pattern": "**/*.test.*",  "labels": ["tests"],                     "priority": 50  },
    { "pattern": "docs/**",      "labels": ["documentation"],             "priority": 10  },
    { "pattern": "**/*.md",      "labels": ["documentation"],             "priority": 5   }
  ]
}
