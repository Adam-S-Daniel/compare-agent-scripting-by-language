{
  "rules": [
    { "pattern": "docs/**", "label": "documentation", "priority": 1 },
    { "pattern": "src/api/**", "label": "api", "priority": 3 },
    { "pattern": "src/**", "label": "core", "priority": 2 },
    { "pattern": "*.test.*", "label": "tests", "priority": 4 },
    { "pattern": "**/*.test.*", "label": "tests", "priority": 4 },
    { "pattern": "*.config.*", "label": "config", "priority": 1 },
    { "pattern": ".github/**", "label": "ci", "priority": 2 },
    { "pattern": "**/*.css", "label": "styles", "priority": 1 },
    { "pattern": "**/*.md", "label": "documentation", "priority": 1 }
  ]
}
