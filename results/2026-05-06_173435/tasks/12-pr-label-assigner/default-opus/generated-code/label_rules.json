{
  "rules": [
    {
      "pattern": "docs/**",
      "label": "documentation",
      "priority": 1
    },
    {
      "pattern": "*.md",
      "label": "documentation",
      "priority": 1
    },
    {
      "pattern": "src/api/**",
      "label": "api",
      "priority": 2
    },
    {
      "pattern": "*.test.*",
      "label": "tests",
      "priority": 3
    },
    {
      "pattern": "tests/**",
      "label": "tests",
      "priority": 3
    },
    {
      "pattern": "src/**",
      "label": "source",
      "priority": 0
    },
    {
      "pattern": "*.yml",
      "label": "ci-cd",
      "priority": 1
    },
    {
      "pattern": ".github/**",
      "label": "ci-cd",
      "priority": 2
    },
    {
      "pattern": "src/ui/**",
      "label": "frontend",
      "priority": 2
    },
    {
      "pattern": "*.css",
      "label": "frontend",
      "priority": 1
    }
  ]
}
