{
  "rules": [
    {
      "pattern": "docs/**",
      "labels": ["documentation"],
      "priority": 1
    },
    {
      "pattern": "src/api/**",
      "labels": ["api"],
      "priority": 2
    },
    {
      "pattern": "src/ui/**",
      "labels": ["ui"],
      "priority": 2
    },
    {
      "pattern": "src/**",
      "labels": ["code"],
      "priority": 10
    },
    {
      "pattern": "*.test.ts",
      "labels": ["tests"],
      "priority": 3
    },
    {
      "pattern": "*.test.tsx",
      "labels": ["tests"],
      "priority": 3
    },
    {
      "pattern": "**/*.md",
      "labels": ["documentation"],
      "priority": 5
    },
    {
      "pattern": ".github/**",
      "labels": ["ci-cd"],
      "priority": 4
    }
  ]
}
