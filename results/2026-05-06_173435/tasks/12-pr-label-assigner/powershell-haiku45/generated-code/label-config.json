{
  "rules": [
    {
      "pattern": "docs/**",
      "labels": ["documentation"],
      "priority": 1
    },
    {
      "pattern": "*.md",
      "labels": ["documentation"],
      "priority": 1
    },
    {
      "pattern": "src/**",
      "labels": ["source"],
      "priority": 1
    },
    {
      "pattern": "src/api/**",
      "labels": ["api"],
      "priority": 2
    },
    {
      "pattern": "src/utils/**",
      "labels": ["utilities"],
      "priority": 2
    },
    {
      "pattern": "Tests/**",
      "labels": ["tests"],
      "priority": 1
    },
    {
      "pattern": "*.test.ps1",
      "labels": ["tests", "unit-test"],
      "priority": 1
    },
    {
      "pattern": "*.integration.ps1",
      "labels": ["tests", "integration-test"],
      "priority": 1
    },
    {
      "pattern": ".github/**",
      "labels": ["ci", "devops"],
      "priority": 1
    },
    {
      "pattern": ".gitignore",
      "labels": ["configuration"],
      "priority": 1
    },
    {
      "pattern": "*.json",
      "labels": ["configuration"],
      "priority": 1
    }
  ]
}
