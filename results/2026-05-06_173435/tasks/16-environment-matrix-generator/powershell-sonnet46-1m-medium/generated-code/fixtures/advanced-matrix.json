{
  "os": ["ubuntu-latest", "windows-latest"],
  "language-version": ["3.10", "3.11"],
  "node-version": ["18", "20"],
  "include": [
    { "os": "macos-latest", "language-version": "3.12", "node-version": "20", "experimental": true }
  ],
  "exclude": [
    { "os": "windows-latest", "language-version": "3.10", "node-version": "18" }
  ],
  "maxParallel": 3,
  "failFast": true
}
