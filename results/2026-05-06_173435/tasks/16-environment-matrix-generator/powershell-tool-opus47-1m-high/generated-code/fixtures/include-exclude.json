{
  "axes": {
    "os":   ["ubuntu-latest", "windows-latest", "macos-latest"],
    "node": [18, 20]
  },
  "exclude": [
    { "os": "windows-latest", "node": 18 },
    { "os": "macos-latest",   "node": 18 }
  ],
  "include": [
    { "os": "ubuntu-latest", "node": 20, "experimental": true },
    { "os": "ubuntu-latest", "node": 22 }
  ],
  "fail-fast": true,
  "max-parallel": 4,
  "max-size": 16
}
