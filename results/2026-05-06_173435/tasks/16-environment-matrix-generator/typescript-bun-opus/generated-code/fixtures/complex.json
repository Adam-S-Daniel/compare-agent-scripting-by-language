{
  "matrix": {
    "os": ["ubuntu-latest", "windows-latest", "macos-latest"],
    "compiler": ["gcc", "clang"],
    "build-type": ["debug", "release"]
  },
  "include": [
    { "os": "ubuntu-latest", "compiler": "gcc", "build-type": "release", "coverage": true }
  ],
  "exclude": [
    { "os": "macos-latest", "compiler": "gcc" }
  ],
  "fail-fast": false,
  "max-parallel": 4,
  "max-combinations": 50
}
