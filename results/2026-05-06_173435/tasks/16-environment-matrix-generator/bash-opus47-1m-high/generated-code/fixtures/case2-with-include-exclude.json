{
  "axes": {
    "os": ["ubuntu-latest", "macos-latest", "windows-latest"],
    "node": ["18", "20"],
    "feature": ["with-tls", "no-tls"]
  },
  "exclude": [
    { "os": "windows-latest", "feature": "no-tls" },
    { "os": "macos-latest", "node": "18" }
  ],
  "include": [
    { "os": "ubuntu-22.04", "node": "20", "feature": "with-tls", "experimental": "true" }
  ],
  "fail-fast": false,
  "max-parallel": 6,
  "max-size": 50
}
