{
  "os":      ["ubuntu-latest", "windows-latest", "macos-latest"],
  "lang":    ["python", "go"],
  "feature": ["fast", "safe"],
  "exclude": [
    { "os": "windows-latest", "feature": "fast" },
    { "os": "macos-latest",   "lang":    "go" }
  ],
  "include": [
    { "os": "ubuntu-latest", "lang": "python", "feature": "fast", "experimental": true },
    { "os": "freebsd-14",    "lang": "rust",   "feature": "safe" }
  ],
  "fail_fast":    false,
  "max_parallel": 6,
  "max_size":     30
}
