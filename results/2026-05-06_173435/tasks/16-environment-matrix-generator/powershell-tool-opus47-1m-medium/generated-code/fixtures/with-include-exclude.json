{
  "os": ["ubuntu-latest", "windows-latest", "macos-latest"],
  "node": [18, 20, 22],
  "exclude": [
    { "os": "windows-latest", "node": 18 },
    { "os": "macos-latest",   "node": 22 }
  ],
  "include": [
    { "os": "ubuntu-latest", "node": 20, "experimental": true },
    { "os": "ubuntu-latest", "node": 23, "experimental": true }
  ],
  "fail-fast": false,
  "max-parallel": 6,
  "max-size": 32
}
