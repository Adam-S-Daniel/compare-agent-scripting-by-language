{
  "axes": {
    "os":      ["ubuntu-latest", "windows-latest", "macos-latest"],
    "python":  ["3.11", "3.12"],
    "feature": ["on", "off"]
  },
  "exclude": [
    { "os": "windows-latest", "feature": "off" },
    { "os": "macos-latest",   "python":  "3.11" }
  ],
  "include": [
    { "os": "ubuntu-latest", "python": "3.13", "feature": "on", "experimental": true }
  ],
  "fail-fast":   false,
  "max-parallel": 6
}
