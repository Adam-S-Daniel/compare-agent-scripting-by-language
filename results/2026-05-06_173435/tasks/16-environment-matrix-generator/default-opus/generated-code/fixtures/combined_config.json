{
  "matrix": {
    "os": ["ubuntu-latest", "windows-latest", "macos-latest"],
    "python-version": ["3.9", "3.10", "3.11"],
    "feature-flag": ["standard", "experimental"]
  },
  "include": [
    {"os": "ubuntu-latest", "python-version": "3.12", "feature-flag": "beta"}
  ],
  "exclude": [
    {"os": "macos-latest", "python-version": "3.9", "feature-flag": "experimental"}
  ],
  "max-parallel": 4,
  "fail-fast": true,
  "max-combinations": 256
}
