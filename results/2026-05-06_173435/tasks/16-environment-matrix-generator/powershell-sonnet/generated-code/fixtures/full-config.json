{
  "os": ["ubuntu-latest", "windows-latest", "macos-latest"],
  "versions": {
    "node": ["18", "20"],
    "python": ["3.10", "3.11"]
  },
  "include": [
    {
      "os": "ubuntu-latest",
      "node": "22",
      "tag": "latest"
    }
  ],
  "exclude": [
    {
      "os": "windows-latest",
      "node": "18"
    }
  ],
  "failFast": true,
  "maxParallel": 10,
  "maxMatrixSize": 256
}
