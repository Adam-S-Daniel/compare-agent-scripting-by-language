{
  "dimensions": {
    "os": ["ubuntu-latest", "windows-latest", "macos-latest"],
    "python": ["3.10", "3.11", "3.12"]
  },
  "include": [
    {"os": "ubuntu-latest", "python": "3.12", "experimental": true}
  ],
  "exclude": [
    {"os": "macos-latest", "python": "3.10"}
  ],
  "fail-fast": true,
  "max-parallel": 4,
  "max-combinations": 256
}
