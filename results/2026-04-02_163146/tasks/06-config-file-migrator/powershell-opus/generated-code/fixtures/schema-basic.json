{
    "server": {
        "required": ["host", "port"],
        "properties": {
            "host": { "type": "string" },
            "port": { "type": "integer" },
            "debug": { "type": "boolean" }
        }
    },
    "database": {
        "required": ["host", "port", "name"],
        "properties": {
            "host": { "type": "string" },
            "port": { "type": "integer" },
            "name": { "type": "string" },
            "max_connections": { "type": "integer" },
            "ssl": { "type": "boolean" }
        }
    }
}
