{
  "matrix": {
    "os": ["ubuntu-latest", "windows-latest", "macos-latest"],
    "node": [16, 18, 20],
    "experimental": [false]
  },
  "exclude": [
    { "os": "macos-latest", "node": "16" }
  ],
  "include": [
    { "os": "ubuntu-latest", "node": "21", "experimental": "true" }
  ],
  "fail-fast": false,
  "max-parallel": 4,
  "max-matrix-size": 256
}
