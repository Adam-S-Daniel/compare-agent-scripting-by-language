{
  "dimensions": {
    "os": ["ubuntu-latest", "windows-latest", "macos-latest"],
    "python": ["3.10", "3.11", "3.12"],
    "debug": [false]
  },
  "include": [
    {"os": "ubuntu-latest", "python": "3.13", "experimental": true}
  ],
  "exclude": [
    {"os": "macos-latest", "python": "3.10"}
  ],
  "fail_fast": false,
  "max_parallel": 4,
  "max_size": 256
}
