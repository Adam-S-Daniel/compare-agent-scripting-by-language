{
  "matrix": {
    "os": ["ubuntu-latest", "macos-latest", "windows-latest"],
    "python": ["3.11", "3.12"],
    "flag": ["default", "experimental"]
  },
  "exclude": [
    {"os": "windows-latest", "flag": "experimental"},
    {"os": "macos-latest", "python": "3.11"}
  ],
  "include": [
    {"os": "ubuntu-latest", "python": "3.12", "flag": "default", "coverage": true}
  ],
  "fail-fast": false,
  "max-parallel": 3,
  "max-size": 100
}
