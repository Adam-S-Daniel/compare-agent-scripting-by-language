{
  "dimensions": {
    "os": ["ubuntu-latest", "windows-latest", "macos-latest"],
    "node": ["18", "20"]
  },
  "exclude": [
    { "os": "windows-latest", "node": "18" }
  ],
  "include": [
    { "os": "ubuntu-latest", "node": "20", "experimental": true }
  ],
  "fail_fast": false,
  "max_parallel": 3,
  "max_size": 50
}
