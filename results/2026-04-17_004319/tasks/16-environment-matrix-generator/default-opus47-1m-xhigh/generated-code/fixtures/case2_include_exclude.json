{
  "matrix": {
    "os": ["ubuntu-latest", "windows-latest", "macos-latest"],
    "node": ["18", "20"],
    "features": ["minimal", "full"]
  },
  "exclude": [
    {"os": "windows-latest", "node": "18"},
    {"os": "macos-latest", "features": "minimal"}
  ],
  "include": [
    {"os": "ubuntu-latest", "node": "20", "features": "full", "coverage": true},
    {"os": "alpine", "node": "20", "features": "minimal"}
  ],
  "fail_fast": true,
  "max_parallel": 4,
  "max_size": 20
}
