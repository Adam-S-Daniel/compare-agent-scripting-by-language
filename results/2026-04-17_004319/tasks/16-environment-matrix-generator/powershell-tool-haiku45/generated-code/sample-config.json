{
  "os": [
    "ubuntu-latest",
    "windows-latest",
    "macos-latest"
  ],
  "language": [
    "node-18",
    "node-20",
    "python-3.10",
    "python-3.11"
  ],
  "include": [
    {
      "os": "macos-latest",
      "language": "node-20",
      "experimental": "true",
      "architecture": "arm64"
    }
  ],
  "exclude": [
    {
      "os": "windows-latest",
      "language": "python-3.10"
    },
    {
      "os": "macos-latest",
      "language": "python-3.10"
    }
  ],
  "maxParallel": 6,
  "failFast": true,
  "maxSize": 50
}
