{
  "os": ["ubuntu-latest", "windows-latest"],
  "language_version": ["3.10", "3.11"],
  "feature_flags": ["default"],
  "include": [
    { "os": "macos-latest", "language_version": "3.12", "feature_flags": "default" }
  ],
  "exclude": [
    { "os": "windows-latest", "language_version": "3.10" }
  ],
  "fail_fast": false,
  "max_parallel": 2,
  "max_size": 10
}
