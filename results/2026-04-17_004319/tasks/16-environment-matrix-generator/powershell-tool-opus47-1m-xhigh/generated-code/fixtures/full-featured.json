{
  "os": ["ubuntu-latest", "macos-latest"],
  "version": ["18", "20", "22"],
  "features": ["default"],
  "exclude": [
    { "os": "macos-latest", "version": "18" }
  ],
  "include": [
    { "os": "windows-latest", "version": "20", "features": "experimental" }
  ],
  "max-parallel": 3,
  "fail-fast": false,
  "max-size": 10
}
