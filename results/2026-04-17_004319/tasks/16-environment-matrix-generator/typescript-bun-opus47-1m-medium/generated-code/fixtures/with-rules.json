{
  "axes": {
    "os": ["ubuntu-latest", "macos-latest", "windows-latest"],
    "node": ["18", "20"]
  },
  "exclude": [
    { "os": "windows-latest", "node": "18" }
  ],
  "include": [
    { "os": "ubuntu-latest", "node": "22", "experimental": true }
  ],
  "features": { "coverage": true },
  "maxParallel": 3,
  "failFast": false,
  "maxSize": 50
}
