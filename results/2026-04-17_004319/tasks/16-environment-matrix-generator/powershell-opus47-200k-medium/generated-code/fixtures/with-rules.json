{
  "axes": {
    "os":   ["ubuntu-latest", "windows-latest", "macos-latest"],
    "node": ["18", "20"]
  },
  "exclude": [
    { "os": "macos-latest", "node": "18" }
  ],
  "include": [
    { "os": "ubuntu-latest", "node": "20", "coverage": true },
    { "os": "ubuntu-latest", "node": "21", "experimental": true }
  ],
  "fail-fast": false,
  "max-parallel": 3,
  "max-size": 20
}
