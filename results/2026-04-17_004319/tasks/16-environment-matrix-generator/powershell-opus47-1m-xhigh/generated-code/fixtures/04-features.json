{
  "dimensions": {
    "os": ["ubuntu-latest", "windows-latest"],
    "node": ["20"],
    "experimental": [false, true]
  },
  "exclude": [
    { "os": "windows-latest", "experimental": true }
  ],
  "include": [
    { "os": "macos-latest", "node": "20", "experimental": false }
  ],
  "maxParallel": 3,
  "failFast": false
}
