{
  "dimensions": {
    "os":      ["ubuntu-latest", "windows-latest", "macos-latest"],
    "node":    ["16", "18", "20"],
    "feature": ["off", "on"]
  },
  "exclude": [
    { "os": "windows-latest", "node": "16" },
    { "os": "macos-latest", "feature": "off" }
  ],
  "include": [
    { "os": "ubuntu-latest", "node": "21", "feature": "on", "experimental": true }
  ],
  "fail-fast": false,
  "max-parallel": 6,
  "max-size": 50
}
