{
  "rules": [
    { "pattern": "src/**",                  "labels": ["needs-review"], "priority": 1 },
    { "pattern": "src/api/admin/**",        "labels": ["needs-review", "security"], "priority": 100 },
    { "pattern": "docs/security/**",        "labels": ["security", "documentation"], "priority": 50 },
    { "pattern": "**/*.test.*",             "labels": ["tests"], "priority": 10 }
  ]
}
