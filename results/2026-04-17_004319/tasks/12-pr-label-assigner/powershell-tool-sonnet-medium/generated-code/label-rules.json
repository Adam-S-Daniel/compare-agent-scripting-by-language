{
  "rules": [
    { "pattern": "docs/**",     "label": "documentation", "priority": 1 },
    { "pattern": "src/api/**",  "label": "api",           "priority": 2 },
    { "pattern": "**/*.test.*", "label": "tests",         "priority": 3 },
    { "pattern": "*.test.*",    "label": "tests",         "priority": 3 },
    { "pattern": "src/**",      "label": "source",        "priority": 4 },
    { "pattern": ".github/**",  "label": "ci",            "priority": 5 }
  ]
}
