{
  "rules": [
    { "pattern": "src/api/**",          "labels": ["api", "backend"],   "priority": 20 },
    { "pattern": "src/web/**",          "labels": ["frontend"],         "priority": 15 },
    { "pattern": "**/*.test.*",         "labels": ["tests"],            "priority": 10 },
    { "pattern": "docs/**",             "labels": ["documentation"],    "priority": 5 },
    { "pattern": ".github/workflows/**", "labels": ["ci", "infra"],     "priority": 8 }
  ]
}
