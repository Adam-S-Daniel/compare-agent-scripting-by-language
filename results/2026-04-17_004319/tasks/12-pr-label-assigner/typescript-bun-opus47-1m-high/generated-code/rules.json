{
  "rules": [
    { "label": "documentation", "patterns": ["docs/**", "*.md"], "priority": 5 },
    { "label": "api", "patterns": ["src/api/**"], "priority": 10 },
    { "label": "tests", "patterns": ["**/*.test.*", "tests/**"], "priority": 7 },
    { "label": "ci", "patterns": [".github/**", ".actrc"], "priority": 3 },
    { "label": "config", "patterns": ["*.json", "*.yml", "*.yaml", "*.toml"], "priority": 1 }
  ]
}
