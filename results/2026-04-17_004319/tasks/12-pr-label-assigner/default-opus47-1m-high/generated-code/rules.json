{
  "rules": [
    {
      "pattern": "docs/**",
      "labels": ["documentation"],
      "priority": 1
    },
    {
      "pattern": "**/*.md",
      "labels": ["documentation"],
      "priority": 1
    },
    {
      "pattern": "src/api/**",
      "labels": ["api", "backend"],
      "group": "area",
      "priority": 20
    },
    {
      "pattern": "src/frontend/**",
      "labels": ["frontend"],
      "group": "area",
      "priority": 20
    },
    {
      "pattern": "src/**",
      "labels": ["source"],
      "group": "area",
      "priority": 5
    },
    {
      "pattern": "**/*.test.*",
      "labels": ["tests"],
      "priority": 10
    },
    {
      "pattern": "**/*.spec.*",
      "labels": ["tests"],
      "priority": 10
    },
    {
      "pattern": ".github/**",
      "labels": ["ci"],
      "priority": 15
    }
  ]
}
