{
  "rules": [
    { "pattern": "docs/**",       "labels": ["documentation"], "priority": 5 },
    { "pattern": "**/*.md",       "labels": ["documentation"], "priority": 6 },
    { "pattern": "src/api/**",    "labels": ["api", "backend"], "priority": 1 },
    { "pattern": "src/web/**",    "labels": ["frontend"],      "priority": 2 },
    { "pattern": "**/*.test.*",   "labels": ["tests"],         "priority": 3 },
    { "pattern": "**/*.ps1",      "labels": ["powershell"],    "priority": 10 },
    { "pattern": ".github/**",    "labels": ["ci"],            "priority": 4 }
  ]
}
