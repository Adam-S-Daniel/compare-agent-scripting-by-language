{
  "rules": [
    { "pattern": "docs/**", "label": "documentation", "priority": 1 },
    { "pattern": "**/*.md", "label": "documentation", "priority": 1 },
    { "pattern": "src/api/**", "label": "api", "priority": 10 },
    { "pattern": "src/frontend/**", "label": "frontend", "priority": 5 },
    { "pattern": "src/backend/**", "label": "backend", "priority": 5 },
    { "pattern": "**/*.test.*", "label": "tests", "priority": 3 },
    { "pattern": "**/*.spec.*", "label": "tests", "priority": 3 },
    { "pattern": ".github/**", "label": "ci", "priority": 2 },
    { "pattern": "package.json", "label": "dependencies", "priority": 4 },
    { "pattern": "bun.lock", "label": "dependencies", "priority": 4 },
    { "pattern": "**/*", "label": "size/S", "group": "size", "priority": 1 },
    { "pattern": "src/**", "label": "size/M", "group": "size", "priority": 5 },
    { "pattern": "src/api/**", "label": "size/L", "group": "size", "priority": 10 }
  ]
}
