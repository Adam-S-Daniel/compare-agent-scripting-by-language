{
  "rules": [
    {
      "pattern": "docs/**",
      "label": "documentation",
      "priority": 100
    },
    {
      "pattern": "**/*.md",
      "label": "documentation",
      "priority": 95
    },
    {
      "pattern": "src/api/**",
      "label": "api",
      "priority": 90
    },
    {
      "pattern": "*.test.*",
      "label": "tests",
      "priority": 80
    },
    {
      "pattern": "src/**",
      "label": "backend",
      "priority": 70
    },
    {
      "pattern": ".github/**",
      "label": "ci/cd",
      "priority": 60
    }
  ]
}
