{
  "os": ["ubuntu-latest", "macos-latest"],
  "language_version": ["3.9", "3.10"],
  "feature_flags": ["flag-a", "flag-b"],
  "exclude": [
    { "os": "macos-latest", "language_version": "3.9", "feature_flags": "flag-b" }
  ],
  "include": [
    { "os": "windows-latest", "language_version": "3.11", "feature_flags": "flag-c" }
  ],
  "max_parallel": 4,
  "fail_fast": false,
  "max_combinations": 100
}
