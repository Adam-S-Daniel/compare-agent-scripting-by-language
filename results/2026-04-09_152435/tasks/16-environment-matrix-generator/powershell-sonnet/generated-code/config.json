{
  "os": ["ubuntu-latest", "windows-latest", "macos-latest"],
  "language_versions": {
    "node":   ["18", "20"],
    "python": ["3.10", "3.11"]
  },
  "feature_flags": {
    "experimental": [false, true]
  },
  "include": [
    { "os": "ubuntu-latest", "node": "22", "experimental": true }
  ],
  "exclude": [
    { "os": "windows-latest", "node": "18", "python": "3.10" }
  ],
  "max_parallel": 8,
  "fail_fast": false,
  "max_matrix_size": 256
}
