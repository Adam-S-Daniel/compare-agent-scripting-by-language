{
  "fail-fast": false,
  "max-parallel": 6,
  "matrix": {
    "language": [
      "3.9",
      "3.10",
      "3.11"
    ],
    "include": [
      {
        "language": "3.12",
        "os": "ubuntu-latest",
        "feature": "experimental"
      }
    ],
    "exclude": [
      {
        "os": "windows-latest",
        "language": "3.9"
      },
      {
        "os": "macos-latest",
        "feature": "no-cache"
      }
    ],
    "os": [
      "ubuntu-latest",
      "windows-latest",
      "macos-latest"
    ],
    "feature": [
      "with-cache",
      "no-cache"
    ]
  }
}
