{
  "dimensions": {
    "os": ["ubuntu-latest", "macos-latest"],
    "python-version": ["3.10", "3.11"],
    "feature-flag": ["enabled", "disabled"]
  },
  "exclude": [
    { "os": "macos-latest", "feature-flag": "disabled" }
  ],
  "include": [
    { "os": "ubuntu-latest", "python-version": "3.12", "feature-flag": "enabled" }
  ],
  "max-parallel": 4,
  "fail-fast": false,
  "max-size": 50
}
