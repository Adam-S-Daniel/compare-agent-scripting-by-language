{
  "matrix": {
    "os": ["ubuntu-latest", "macos-latest"],
    "lang": ["go", "rust"],
    "feature": ["default", "experimental"],
    "exclude": [
      {"os": "macos-latest", "lang": "rust", "feature": "experimental"}
    ],
    "include": [
      {"os": "ubuntu-latest", "lang": "go", "feature": "default", "coverage": true}
    ]
  },
  "fail_fast": true,
  "max_parallel": 4,
  "max_matrix_size": 50
}
