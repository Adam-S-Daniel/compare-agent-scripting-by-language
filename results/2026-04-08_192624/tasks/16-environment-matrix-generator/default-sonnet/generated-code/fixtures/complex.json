{
  "os": ["ubuntu-latest", "windows-latest", "macos-latest"],
  "language_versions": {
    "python": ["3.10", "3.11", "3.12"]
  },
  "feature_flags": {
    "experimental": [true, false]
  },
  "include": [
    {
      "os": "ubuntu-latest",
      "python-version": "3.12",
      "nightly": true
    }
  ],
  "exclude": [
    {
      "os": "windows-latest",
      "python-version": "3.10"
    }
  ],
  "max_parallel": 4,
  "fail_fast": false,
  "max_size": 256
}
